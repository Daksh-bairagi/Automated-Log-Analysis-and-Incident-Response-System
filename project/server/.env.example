# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/log_analyzer
DB_NAME=log_analyzer

# Redis (for BullMQ queues)
REDIS_URL=redis://localhost:6379
QUEUE_ENABLED=true
QUEUE_ANALYSIS_NAME=analysis
QUEUE_NOTIFICATION_NAME=notifications

# Log Configuration
LOG_DIR=../logs
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Notifications (optional — leave blank to disable)
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
WEBHOOK_URL=

# JWT Auth (Phase 2)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h
